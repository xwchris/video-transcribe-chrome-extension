{
  "manifest_version": 3,
  "name": "Videosays: Video to Text",
  "short_name": "Videosays",
  "version": "0.1.0",
  "description": "Submit the current public video page to Videosays and turn speech into transcript text.",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["https://api.videosays.com/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Transcribe with Videosays",
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
